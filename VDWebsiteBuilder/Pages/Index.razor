@page "/"
<style>
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .hero-wrapper {
        min-height: 100vh;
        background: linear-gradient(135deg, #f3e5f5 0%, #ffffff 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', system-ui, sans-serif;
        position: relative;
        overflow: hidden;
    }
    .blob {
        position: absolute;
        width: 500px;
        height: 500px;
        background: rgba(142, 68, 173, 0.1);
        filter: blur(80px);
        border-radius: 50%;
        z-index: 0;
    }
    .glass-card {
        position: relative;
        z-index: 1;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 50px;
        padding: 5rem 2rem;
        max-width: 850px;
        width: 90%;
        text-align: center;
        box-shadow: 0 20px 40px rgba(142, 68, 173, 0.05);
        animation: fadeInUp 0.8s ease-out;
    }
    .hero-title {
        font-size: clamp(3rem, 10vw, 5.5rem);
        font-weight: 900;
        background: linear-gradient(45deg, #6a1b9a, #ce93d8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 1rem;
        letter-spacing: -2px;
    }
    .hero-subtitle {
        color: #5e35b1;
        font-size: 1.3rem;
        font-weight: 400;
        max-width: 550px;
        margin: 0 auto 3.5rem;
        line-height: 1.5;
        opacity: 0.8;
    }
    .btn-main {
        background: #8e24aa;
        color: white;
        padding: 1.2rem 3rem;
        border-radius: 20px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        display: inline-block;
        box-shadow: 0 10px 25px rgba(142, 36, 170, 0.3);
    }
        .btn-main:hover {
            transform: scale(1.05);
            background: #7b1fa2;
            box-shadow: 0 15px 35px rgba(142, 36, 170, 0.4);
            color: white;
        }
    .tech-badges {
        margin-top: 5rem;
        display: flex;
        justify-content: center;
        gap: 2.5rem;
    }
        .tech-badges span {
            color: #9c27b0;
            font-weight: 700;
            font-family: monospace;
            font-size: 1rem;
            opacity: 0.4;
        }
</style>

<div class="hero-wrapper">
    <div class="blob" style="top: -100px; left: -100px;"></div>
    <div class="blob" style="bottom: -100px; right: -100px; background: rgba(106, 27, 154, 0.07);"></div>

    <div class="glass-card">
        <h1 class="hero-title">VD Website Builder</h1>

        <p class="hero-subtitle">
            Начни свой путь к полноценной разработке сайтов!
        </p>

        <a href="theory" class="btn-main">Начать!</a>

        <div class="tech-badges">
            <span>[ BLAZOR ]</span>
        </div>
    </div>
</div>