@page "/editor"
@using System.Text.Json
@inject IJSRuntime JS


<div class="app-grid">

    <section class="panel tools">
        
        <h4>Инструменты</h4>
        <button class="btn btn-primary mb-2" @onclick='() => Add("h1")'>+ Заголовок</button>
        <button class="btn btn-primary mb-2" @onclick='() => Add("p")'>+ Абзац</button>
        <button class="btn btn-primary mb-2" @onclick='() => Add("img")'>+ Картинка</button>

        @if (selectedElement != null)
        {
            <div class="mt-4 pt-3 border-top">
                <div class="d-grid gap-2">
                    @if (!showUndo)
                    {
                        <button class="btn btn-info fw-bold text-white shadow-sm" @onclick="ExecuteMagic">
                            Улучшить блок, попросив помощи у ???
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-outline-danger fw-bold shadow-sm" @onclick="UndoMagic">
                            Отказаться от помощи ???
                        </button>
                        <small class="text-muted text-center" style="font-size: 0.7rem;">
                            Вернуть мои авторские настройки
                        </small>
                    }
                </div>
            </div>
            <div class="edit-panel p-3 border rounded bg-light">
                <h6>Настройки @selectedElement.Tag</h6>
                <label>Текст/Контент:</label>
                <input class="form-control mb-2"
                       @bind="selectedElement.Content"
                       @bind:after="SaveToBrowser" />
                <label>Цвет текста:</label>
                <input type="color" class="form-control form-control-color mb-2 w-100"
                       @bind="selectedElement.Color"
                       @bind:after="SaveToBrowser" />
                <label>Размер(@selectedElement.FontSize px):</label>
                <input type="range" class="form-range mb-2"
                       min="10" max="1000"
                       @bind="selectedElement.FontSize"
                       @bind:after="SaveToBrowser" />
                <label>Выравнивание:</label>
                <select class="form-select mb-2"
                        @bind="selectedElement.TextAlign"
                        @bind:after="SaveToBrowser">
                    <option value="left">Слева</option>
                    <option value="center">По центру</option>
                    <option value="right">Справа</option>
                </select>
            </div>
            <button class="btn btn-warning w-100 mt-4 fw-bold shadow-sm"
                    style="border-radius: 10px; border: 2px solid #ffca28;"
                    @onclick="ShowTheory">
                Непонятно? Нажми, нажми, нажми меня! 💡
            </button>
        }
        @if (showTheoryModal)
        {
            <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 9999; display: flex; align-items: center; justify-content: center;" @onclick="() => showTheoryModal = false">
                <div class="bg-white p-4 rounded shadow-lg" style="max-width: 450px; width: 90%; color: black;" @onclick:stopPropagation>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="m-0">💡 Шпаргалка</h4>
                        <button class="btn-close" @onclick="() => showTheoryModal = false"></button>
                    </div>
                    <hr />
                    <p style="font-size: 1.1rem; line-height: 1.5;">@currentTheory</p>
                    <div class="text-end mt-4">
                        <button class="btn btn-primary" @onclick="() => showTheoryModal = false">Допустим...</button>
                    </div>
                </div>
            </div>
        }
        <hr />
        <button class="btn btn-success w-100 mb-2" @onclick="ExportToHtml">Скачать сайт (.html)</button>
        <button class="btn btn-danger w-100" @onclick="ClearAll">Очистить всё</button>
    </section>

    <section class="panel preview">
        <h4>Превью</h4>
        <div class="canvas border p-3 bg-white" style="min-height: 400px; font-family: sans-serif;">
            @foreach (var el in elements)
            {

                <div @onclick="() => Select(el)"
                     style="cursor:pointer; margin-bottom: 10px; border: @(el == selectedElement ? "2px solid blue" : "1px dashed transparent");">

                    @if (el.Tag == "img")
                    {
                        <div style="text-align: @(el.TextAlign);">
                            <img src="@el.Content" style="width: @(el.FontSize + "px"); height: auto;" />
                        </div>
                    }
                    else
                    {
                        @if (el.Tag == "h1")
                        {
                            <h1 style="color: @(el.Color); font-size: @(el.FontSize + "px"); text-align: @(el.TextAlign);">
                                @el.Content
                            </h1>
                        }
                        else if (el.Tag == "p")
                        {
                            <p style="color: @(el.Color); font-size: @(el.FontSize + "px"); text-align: @(el.TextAlign);">
                                @el.Content
                            </p>
                        }
                    }
                    <div class="d-flex justify-content-center mt-3">
                        <button class="btn btn-outline-danger btn-sm"
                                style="width: fit-content; padding: 3px 15px; font-size: 0.7rem; border-radius: 20px; transition: 0.3s;"
                                @onclick="() => RemoveElement(el)">
                            Удалить блок
                        </button>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="panel code-view">
        <h4>Интерактивный тренажер</h4>
        <div class="code-container">
            @foreach (var el in elements)
            {
                <div class="code-card mb-4 p-3 bg-dark rounded shadow-sm">
                    <div class="p-2 mb-2" style="background: #1e1e1e; border-radius: 4px; font-family: monospace;">
                        <code>@el.GetColoredHtml()</code>
                    </div>
                    <div class="explanation-list">
                        @foreach (var prop in el.GetPropertyBreakdown())
                        {
                            <div class="d-flex border-bottom border-secondary py-1 small">
                                <b style="width: 35%; color: #4ec9b0;">@prop.Key</b>
                                <span style="width: 25%; color: #ce9178;">@prop.Value</span>
                                <span class="ms-2 flex-grow-1" style="color: #b5cea8;">
                                    - @prop.Desc
                                </span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </section>

</div>

@code {
    private const string StorageKey = "vdwebsitebuilder_project_save";
    private List<VisualElement> elements = new();
    private VisualElement? selectedElement;
    private bool showTheoryModal = false;
    private string currentTheory = "";
    public class VisualElement
    {
        private string currentTheme = "theme-light";

        private void SetTheme(string themeName)
        {
            currentTheme = themeName;
        }
        public string Tag { get; set; } = "p";
        public string Content { get; set; } = "Новый текст";
        public string Color { get; set; } = "#000000";
        public string FontSize { get; set; } = "18";
        public string TextAlign { get; set; } = "left";
        public Microsoft.AspNetCore.Components.MarkupString GetColoredHtml()
        {
            string tagColor = "#569cd6";
            string attrColor = "#9cdcfe";
            string valColor = "#ce9178";
            if (Tag == "img")
                return (Microsoft.AspNetCore.Components.MarkupString)$@"<span style='color:{tagColor}'>&lt;img</span> <span style='color:{attrColor}'>src</span>=<span style='color:{valColor}'>""{Content}""</span> <span style='color:{attrColor}'>style</span>=<span style='color:{valColor}'>""width:{FontSize}px;""</span><span style='color:{tagColor}'>&gt;</span>";

            return (Microsoft.AspNetCore.Components.MarkupString)$@"<span style='color:{tagColor}'>&lt;{Tag}</span> <span style='color:{attrColor}'>style</span>=<span style='color:{valColor}'>""color:{Color}; font-size:{FontSize}px; text-align:{TextAlign};""</span><span style='color:{tagColor}'>&gt;</span>{Content}<span style='color:{tagColor}'>&lt;/{Tag}&gt;</span>";
        }
        public List<(string Key, string Value, string Desc)> GetPropertyBreakdown()
        {
            var list = new List<(string, string, string)>();
            list.Add(("<" + Tag + ">", "Тег", "Тип элемента."));
            list.Add(("color", Color, "Цвет текста."));
            list.Add(("font-size", FontSize + "px", "Размер шрифта."));
            list.Add(("text-align", TextAlign, "Выравнивание."));
            return list;
        }
    }
    private void ShowTheory()
    {
        if (selectedElement == null)
        {
            currentTheory = "Выбери элемент, чтобы я узнал о нем подробнее!";
        }
        else
        {
            currentTheory = selectedElement.Tag switch
            {
                "h1" => "<h1> — Заголовок. Нужен для названия страницы.",
                "p" => "<p> — Абзац. Для обычного текста.",
                "img" => "<img> — Картинка. Не требует закрывающего тега.",
                _ => "Это стандартный HTML тег."
            };
        }
        showTheoryModal = true;
    }
    protected override async Task OnInitializedAsync() => await LoadFromBrowser();
    private async Task Add(string tag)
    {
        var newEl = new VisualElement { Tag = tag };
        if (tag == "img") { newEl.Content = ""; newEl.FontSize = "150"; }
        elements.Add(newEl);
        selectedElement = newEl;
        await SaveToBrowser();
    }
    private async Task RemoveElement(VisualElement el)
    {
        elements.Remove(el);
        if (selectedElement == el) selectedElement = null;
        await SaveToBrowser();
    }
    private async Task SaveToBrowser()
    {
        try
        {
            var json = JsonSerializer.Serialize(elements);
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
        }
        catch { }
    }
    private async Task LoadFromBrowser()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", StorageKey);
            if (!string.IsNullOrEmpty(json))
            {
                elements = JsonSerializer.Deserialize<List<VisualElement>>(json) ?? new();
                StateHasChanged();
            }
        }
        catch { }
    }
    private void Select(VisualElement el) => selectedElement = el;
    private async Task ClearAll()
    {
        elements.Clear();
        selectedElement = null;
        await SaveToBrowser();
    }
    private async Task ExportToHtml()
    {
        var htmlBody = "";
        foreach (var el in elements)
        {
            if (el.Tag == "img")
                htmlBody += $"<div style='text-align:{el.TextAlign}'><img src='{el.Content}' style='width:{el.FontSize}px;'></div>";
            else
                htmlBody += $"<{el.Tag} style='color:{el.Color}; font-size:{el.FontSize}px; text-align:{el.TextAlign};'>{el.Content}</{el.Tag}>";
        }
        var finalHtml = $@"<!DOCTYPE html>
        <html>
        <head>
            <meta charset='utf-8'>
            <link href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css' rel='stylesheet'>
            <title>Мой учебный сайт</title>
        </head>
        <body style='padding:40px;'>
            <div class='container'>{htmlBody}</div>
        </body>
        </html>";

        await JS.InvokeVoidAsync("downloadFile", "index.html", finalHtml);
    }
    private string backupJson = "";
    private bool showUndo = false;
    private async Task ExecuteMagic()
    {
        backupJson = JsonSerializer.Serialize(elements);
        foreach (var el in elements)
        {
            el.TextAlign = "center";
            if (el.Tag == "h1")
            {
                el.Color = "#2c3e50";
                el.FontSize = "42";
            }
            else if (el.Tag == "p")
            {
                el.Color = "#7f8c8d";
                el.FontSize = "18";
            }
        }

        showUndo = true;
        await SaveToBrowser();
    }

    private async Task UndoMagic()
    {
        if (!string.IsNullOrEmpty(backupJson))
        {
            elements = JsonSerializer.Deserialize<List<VisualElement>>(backupJson) ?? elements;
            showUndo = false;
            await SaveToBrowser();
        }
    }

}