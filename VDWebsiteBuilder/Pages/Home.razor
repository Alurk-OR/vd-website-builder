@page "/"
@using VD Website Builder.Models;
<div class="app-grid">
	<section class="panel tools">
		<h4>Инструменты</h4>
		<button class="btn" @onclick='() => Add("h1")'>+ Заголовок</button>
		<button class="btn" @onclick='() => Add("p")'>+ Абзац</button>
		@if (selectedElement != null)
		{
			<hr />
			<h5>Редактирование</h5>
			<label>Текст:</label>
			<input class="input-text" @bind="selectedElement.Content" @bind:event="oninput" />
			<label>Цвет:</label>
			<input type="color" @bind="selectedElement.Color" />
		}
		<hr />
		<button class="btn-clear" @onclick="() => elements.Clear()">Очистить</button>
	</section>
	<section class="panel preview">
		<h4>Превью</h4>
		<div class="canvas">
			@foreach (var el in elements)
			{
				<div @onclick="() => Select(el)" class='@(el == selectedElement ? "selected" : "")'>
					@if (el.Tag == "h1")
					{
						<h1 style="color:@el.Color">@el.Content</h1>
					}
					else if (el.Tag == "p")
					{

						<p style="color:@el.Color">@el.Content</p>
					}
				</div>
			}
		</div>
	</section>
	<section class="panel code-view">
		<h4>Тренажер</h4>
		@foreach (var el in elements)
		{
			<div class="code-card">
				<code class="html-text">@el.GetHtmlCode()</code>
				<div class="explanation">@el.GetExplanation()</div>
			</div>
		}
	</section>
</div>
@code {
	private List<VisualElement> elements = new();
	private VisualElement? selectedElement;
	private void Add(string tag)
	{
		var newEl = new VisualElement { Tag = tag, Content = "Новый текст" };
		elements.Add(newEl);
		selectedElement = newEl;
	}
	private void Select(VisualElement el) => selectedElement = el;
}